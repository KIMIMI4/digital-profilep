Each page layout is designed with Clarity and Conciseness as the guiding characteristics, ensuring the user is never overwhelmed with data blocks.
Page 1: Home View (Home.ts)
Focuses on Simplicity. It gives an immediate, striking value proposition with clear actions.
TypeScript
import { Route } from '../types';

export const HomeRoute: Route = {
  path: '/',
  title: 'Home',
  render: () => `
    <section class="hero-section">
      <h1>Hi, I'm Alex Mercer</h1>
      <p class="subtitle">Full-Stack TypeScript Engineer transforming complex problems into elegant user interfaces.</p>
      <div class="cta-group">
        <a href="/portfolio" class="btn btn-primary">View My Work</a>
        <a href="/contact" class="btn btn-secondary">Get In Touch</a>
      </div>
    </section>
  `
};
